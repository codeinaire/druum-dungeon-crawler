// Encounter table for floor 1. Weights are u32; sum to 100 for designer
// ergonomics. WeightedIndex normalises automatically.
//
// Inline EnemySpec until #17 ships EnemyDb (D-A4).
//
// `accuracy` / `evasion` on `derived_stats` are 0-100 percentages — see the
// doc on `DerivedStats::accuracy` in `src/plugins/party/character.rs`.
// Party derives land at acc≈73 / eva≈13 for level 1 (debug-party BaseStats),
// so authored enemy values must stay in the same range or hit chances become
// degenerate. Reference points: Goblin = fodder (50/3), Captain = mini-boss
// (70/5), Cave Spider = dangerous (75/15).

(
    id: "b1f_encounters",
    entries: [
        // Common: Single Goblin (50%)
        (
            weight: 50,
            group: (
                enemies: [
                    (
                        id: "goblin",
                        name: "Goblin",
                        base_stats: (strength: 8, intelligence: 4, piety: 4, vitality: 8, agility: 6, luck: 4),
                        derived_stats: (
                            max_hp: 30, current_hp: 30, max_mp: 0, current_mp: 0,
                            attack: 8, defense: 5, magic_attack: 0, magic_defense: 2,
                            speed: 6, accuracy: 50, evasion: 3,
                        ),
                        ai: RandomAttack,
                    ),
                ],
            ),
        ),
        // Uncommon: Pair of Goblins (30%)
        (
            weight: 30,
            group: (
                enemies: [
                    (
                        id: "goblin",
                        name: "Goblin",
                        base_stats: (strength: 8, intelligence: 4, piety: 4, vitality: 8, agility: 6, luck: 4),
